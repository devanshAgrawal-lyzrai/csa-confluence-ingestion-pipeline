# --- Confluence ---
# Your Atlassian instance base URL (no trailing slash)
CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net
# Your Atlassian account email (used for HTTP Basic Auth)
CONFLUENCE_EMAIL=you@yourcompany.com
# API token from https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=

# --- Lyzr Agent (page summary + tags + relevancy score) ---
LYZR_API_KEY=
LYZR_AGENT_ID=
LYZR_USER_ID=

# --- Lyzr Knowledge Base (parse + train APIs) ---
# Base URL for the Lyzr API (no trailing slash)
LYZR_KB_BASE_URL=https://agent-prod.studio.lyzr.ai
# KB ID from your Lyzr Studio knowledge base settings
LYZR_KB_ID=

# --- Chunking (passed to /v3/parse/text/) ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=100

# --- PostgreSQL ---
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
#
# For a local Docker container, start it with:
#   docker run --name kb-postgres \
#     -e POSTGRES_USER=postgres \
#     -e POSTGRES_PASSWORD=postgres \
#     -e POSTGRES_DB=kb_ingestion \
#     -p 5432:5432 \
#     -d postgres:16
#
# Then this URL works as-is:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kb_ingestion

# --- Logging ---
# INFO (default) or DEBUG for verbose output
LOG_LEVEL=INFO
