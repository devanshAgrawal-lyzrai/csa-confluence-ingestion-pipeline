      "updated": 1700000000000, "link": null, "locked": false,
      "text": "⑤ KB Parse API\nSplits plain text into chunks\n───────────────────\nPOST /v3/parse/text/\nchunk_size=1000, overlap=100\nAll chunks share the same source\n→ array of raw chunk objects",
      "fontSize": 12, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 11,
      "containerId": "s8",
      "originalText": "⑤ KB Parse API\nSplits plain text into chunks\n───────────────────\nPOST /v3/parse/text/\nchunk_size=1000, overlap=100\nAll chunks share the same source\n→ array of raw chunk objects",
      "lineHeight": 1.25
    },
