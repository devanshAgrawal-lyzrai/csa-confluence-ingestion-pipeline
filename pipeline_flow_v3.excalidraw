    {
      "id": "t9", "type": "text",
      "x": 2260, "y": 362, "width": 320, "height": 156,
      "angle": 0, "strokeColor": "#7c3700", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null,
      "roundness": null, "seed": 182, "version": 1, "versionNonce": 182,
      "isDeleted": false, "boundElements": [],
      "updated": 1700000000000, "link": null, "locked": false,
      "text": "⑥ Assign Deterministic Chunk IDs\nInternal step — no API call\n───────────────────\nchunk_id = sha256(page_id + chunk_text)\nSame content = same ID across re-syncs\nNo orphaned vectors on unchanged chunks\n───────────────────\nAlso fills extra_info per chunk:\n{page_id, title, url, labels, tags}",
      "fontSize": 12, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 11,
      "containerId": "s9",
      "originalText": "⑥ Assign Deterministic Chunk IDs\nInternal step — no API call\n───────────────────\nchunk_id = sha256(page_id + chunk_text)\nSame content = same ID across re-syncs\nNo orphaned vectors on unchanged chunks\n───────────────────\nAlso fills extra_info per chunk:\n{page_id, title, url, labels, tags}",
      "lineHeight": 1.25
    },
